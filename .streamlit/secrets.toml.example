# Copy this file to `.streamlit/secrets.toml` and fill in your key.
# `.streamlit/secrets.toml` is gitignored and must never be committed.
#
#   cp .streamlit/secrets.toml.example .streamlit/secrets.toml
#
# The floating report assistant (TrackC/chat_assistant.py) reads these.

# Required — your OpenAI API key.
OPENAI_API_KEY = "sk-..."

# Optional — override the model (defaults to gpt-4o-mini).
# OPENAI_MODEL = "gpt-4o-mini"
